# Copy this file to `.env` and adjust per environment.
#
# SQLite is the local-dev database (Docker is unavailable in this environment).
# Migration to Postgres is a one-line change: swap `provider = "sqlite"` to
# `provider = "postgresql"` in `prisma/schema.prisma` and update this URL.
DATABASE_URL="file:./prisma/dev.db"

# Secret for iron-session encrypted cookies (min 32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-real-32-char-secret-in-prod"
