    "bcryptjs": "^3.0.3",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "slugify": "^1.6.9",
    "zod": "^4.4.3"
  },
  "pnpm": {
